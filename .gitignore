# Bench evolve cache (locally regenerated by _lib.sampler / _lib.rebaseline /
# _lib.extract_best / _lib.prepare_phase). Safe to delete.
input/*/evolve/cache/

# Bench evolve final artifact (locally regenerated by _lib.finalize from the
# last phase's best_program.py — depends on local evolution run state).
input/*/evolve/final_program.py

# OpenEvolve per-phase output (LLM evolution artifacts).
input/*/evolve/phase*/openevolve_output*/
input/*/evolve/phase*/__pycache__/
